diff --git a/applications/app.h b/applications/app.h
index c687645f..7648c5ba 100644
--- a/applications/app.h
+++ b/applications/app.h
@@ -88,4 +88,15 @@ void app_custom_start(void);
 void app_custom_stop(void);
 void app_custom_configure(app_configuration *conf);
 
+// RC-failsafe arbiter (app_custom.c) <-> comm gate (commands.c)
+// When the arbiter is driving (manual mode or auto-failover), computer
+// motor/servo commands over comm are ignored so there is a single writer.
+bool app_arbiter_blocks_comm(void);
+// Called by commands.c whenever a motor/servo command arrives over comm,
+// so the arbiter can detect computer liveness for auto-failover.
+void app_arbiter_report_comm_cmd(void);
+// Called by commands.c when a servo command is applied (auto passthrough), so
+// the arbiter reports the actual servo position back to the PC in every mode.
+void app_arbiter_note_servo(float pos);
+
 #endif /* APP_H_ */
