+// RC-failsafe arbiter feedback (custom app data from firmware).
+// Payload after the COMM id: [0xA5, mode, servo(i16 x1000), steer(i16 x1000), thr(i16 x1000)]
+class VescPacketCustomApp : public VescPacket
+{
+public:
+  explicit VescPacketCustomApp(std::shared_ptr<VescFrame> raw);
+
+  bool   valid()    const;   ///< marker 0xA5 present
+  int    mode()     const;   ///< 0 disarm, 1 manual, 2 auto, 3 auto-failover(RC)
+  double servo()    const;   ///< applied servo position 0..1
+  double steer()    const;   ///< RC steering -1..1
+  double throttle() const;   ///< RC throttle -1..1
+
+private:
+  bool valid_;
+  int mode_;
+  double servo_;
+  double steer_;
+  double throttle_;
+};
