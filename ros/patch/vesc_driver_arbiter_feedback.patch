 REGISTER_PACKET_TYPE(COMM_FW_VERSION, VescPacketFWVersion)
 
+VescPacketCustomApp::VescPacketCustomApp(std::shared_ptr<VescFrame> raw)
+: VescPacket("CustomApp", raw)
+{
+  // payload_.first[0] = COMM id; data starts at +1
+  valid_ = (*(payload_.first + 1) == 0xA5);
+  mode_ = *(payload_.first + 2);
+  uint16_t sv = (static_cast<uint16_t>(*(payload_.first + 3)) << 8) | *(payload_.first + 4);
+  uint16_t st = (static_cast<uint16_t>(*(payload_.first + 5)) << 8) | *(payload_.first + 6);
+  uint16_t th = (static_cast<uint16_t>(*(payload_.first + 7)) << 8) | *(payload_.first + 8);
+  servo_    = static_cast<int16_t>(sv) / 1000.0;
+  steer_    = static_cast<int16_t>(st) / 1000.0;
+  throttle_ = static_cast<int16_t>(th) / 1000.0;
+}
+bool   VescPacketCustomApp::valid()    const {return valid_;}
+int    VescPacketCustomApp::mode()     const {return mode_;}
+double VescPacketCustomApp::servo()    const {return servo_;}
+double VescPacketCustomApp::steer()    const {return steer_;}
+double VescPacketCustomApp::throttle() const {return throttle_;}
+
+REGISTER_PACKET_TYPE(COMM_CUSTOM_APP_DATA, VescPacketCustomApp)
